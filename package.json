{
  "name": "ff-for-github",
  "version": "0.1.0",
  "private": true,
  "description": "Shows whether a GitHub pull request can be fast-forward merged.",
  "type": "module",
  "scripts": {
    "ci": "tsc --noEmit && oxlint && oxfmt --check",
    "fix": "oxlint --fix",
    "fmt": "oxfmt",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@wxt-dev/module-solid": "^1.1.4",
    "chrome-types": "^0.1.425",
    "eslint-plugin-solid": "^0.14.5",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "wxt": "^0.20.19"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ]
  }
}
